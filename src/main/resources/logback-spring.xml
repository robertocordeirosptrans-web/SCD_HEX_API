<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        Logback Spring — configuração com MDC para rastreabilidade e auditoria.

        Campos do MDC (populados pelo AuditContextFilter + JwtAuthFilter):
          %X{traceId}   → UUID único por request
          %X{userId}    → ID do usuário autenticado ("-" se anônimo)
          %X{sessionId} → ID da sessão ("-" se pré-autenticação)
          %X{ip}        → IP de origem

        Padrão de log:
          timestamp LEVEL [traceId] [userId] [sessionId] logger — mensagem
    -->

    <!-- ── Propriedades ────────────────────────────────────────────────── -->
    <springProperty scope="context" name="APP_NAME"
                    source="spring.application.name" defaultValue="SCD_API"/>
    <property name="LOG_DIR"     value="logs"/>
    <property name="LOG_PATTERN"
              value="%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%X{traceId:--}] [user=%X{userId:--}] [session=%X{sessionId:--}] [ip=%X{ip:--}] %logger{36} - %msg%n"/>

    <!-- ── Appender: Console ───────────────────────────────────────────── -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ── Appender: Arquivo principal (rotação diária, 30 dias) ─────── -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${APP_NAME}.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ── Appender: Arquivo exclusivo de auditoria (rotação diária, 90 dias) ── -->
    <appender name="AUDIT_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_DIR}/${APP_NAME}-audit.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOG_DIR}/${APP_NAME}-audit.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>90</maxHistory>
            <totalSizeCap>2GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>${LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- ── Logger de auditoria: captura apenas linhas [AUDIT] ─────────── -->
    <logger name="br.sptrans.scd.audit.application.service.AuditService"
            level="INFO" additivity="false">
        <appender-ref ref="AUDIT_FILE"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <!-- ── Níveis por pacote ──────────────────────────────────────────── -->
    <logger name="br.sptrans.scd" level="INFO"/>
    <logger name="org.springframework.security" level="WARN"/>
    <logger name="org.hibernate.SQL" level="WARN"/>
    <logger name="org.hibernate.orm.jdbc.bind" level="WARN"/>

    <!-- ── Root ───────────────────────────────────────────────────────── -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>
