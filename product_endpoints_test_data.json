      "autenticacao": true,
      "campos_obrigatorios": [
        "codProduto",
        "desProduto",
        "desEmissorResponsavel",
        "codTipoProduto",
        "codTecnologia",
        "codModalidade",
        "codFamilia",
        "codEspecie",
        "codEntidade",
        "codClassificacaoPessoa"
      ],
      "exemplo_request": {
        "codProduto": "PROD001",
        "desProduto": "Cartão de Débito Premium",
        "desEmissorResponsavel": "Banco X",
