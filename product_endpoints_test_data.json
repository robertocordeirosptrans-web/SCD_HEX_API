  "resumo": {
    "total_endpoints": 5,
    "por_controlador": {
      "ProductController": 5
    },
    "por_metodo": {
      "POST": 2,
      "PUT": 1,
      "PATCH": 2
    }
  },
  "autenticacao": {
    "tipo": "Bearer Token",
    "header": "Authorization: Bearer {token}",
    "descricao": "Todos os endpoints requerem autenticação via JWT token e papel ADMIN"
  },
  "permissoes": [
    "PRO_CADPRO - Cadastrar produtos",
    "PRO_LISPRO - Listar produtos",
    "PRO_BUSPROPORCOD - Buscar produto por código",
    "PRO_ATUPRO - Atualizar produtos",
    "PRO_ATIPRO - Ativar produtos",
    "PRO_INAPRO - Inativar produtos"
  ],
  "flags_validas": {
    "bloqueio": ["S", "N"],
    "inicializado": ["S", "N"],
    "comercializado": ["S", "N"],
    "restManual": ["S", "N"]
  },
  "fluxo_completo": [
    "1. POST /api/v1/product - Criar produto",
    "2. POST /api/v1/product/{codProduto}/versions - Criar versão do produto",
    "3. PATCH /api/v1/product/{codProduto}/activate - Ativar produto",
    "4. PUT /api/v1/product/{codProduto} - Atualizar produto conforme necessário",
    "5. PATCH /api/v1/product/{codProduto}/inactivate - Inativar quando desejado"
  ],
  "observacoes": [
    "Todos os códigos (codTipoProduto, codTecnologia, etc) devem ser válidos no sistema",
    "Datas devem estar em formato ISO 8601 (YYYY-MM-DDTHH:MM:SS)",
    "Flags devem ser 'S' (Sim) ou 'N' (Não)",
    "Um produto pode ter múltiplas versões ao longo do tempo",
    "O versionamento permite rastrear mudanças no produto",
    "Requer permissão de ADMIN para criar/atualizar produtos"
  ]
}
