      "path_parameters": {
        "codProduto": "PROD001"
      },
      "descricao": "Atualiza dados de um produto",
      "autenticacao": true,
      "campos_obrigatorios": [
        "desProduto",
        "desEmissorResponsavel",
        "codTipoProduto",
        "codTecnologia",
        "codModalidade",
        "codFamilia",
        "codEspecie",
