      "controlador": "ProductController",
      "metodo": "PATCH",
      "endpoint": "/api/v1/product/{codProduto}/activate",
      "path_parameters": {
        "codProduto": "PROD001"
      },
      "descricao": "Ativa um produto",
      "autenticacao": true,
      "campos_obrigatorios": [],
      "exemplo_request": {}
    },
    {
      "id": 4,
      "controlador": "ProductController",
      "metodo": "PATCH",
      "endpoint": "/api/v1/product/{codProduto}/inactivate",
      "path_parameters": {
