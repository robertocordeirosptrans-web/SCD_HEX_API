  "guia_utilizacao": [
    "1. Abrir o arquivo JSON correspondente ao módulo desejado",
    "2. Localizar o endpoint desejado por controlador ou método HTTP",
    "3. Utilizar os dados de exemplo para realizar testes",
    "4. Campos obrigatórios são indicados em 'campos_obrigatorios'",
    "5. Campos opcionais estão em 'campos_opcionais' ou 'exemplo_request'",
    "6. Path parameters devem ser substituídos nos valores reais",
    "7. Usar o token Bearer obtido em /auth/login para autenticação"
  ],
  "fluxos_principais": {
    "autenticacao": [
      "1. POST /api/v1/auth/login - Obter token",
      "2. Usar token em Authorization header para demais requisições",
      "3. POST /api/v1/auth/refresh-token - Renovar token antes de expirar"
    ],
    "criar_canal": [
      "1. POST /api/v1/sales-channels - Criar canal de venda",
      "2. POST /api/v1/product-channels - Associar produtos ao canal",
      "3. POST /api/v1/agreement-validities - Definir vigência do convênio",
      "4. POST /api/v1/recharge-limits - Definir limites de recarga"
    ],
    "solicitar_cartoes": [
      "1. POST /api/v1/initialized-cards - Criar solicitação",
      "2. POST /api/v1/initialized-cards/{codCanal}/{nrSolicitacao}/lotes - Associar lotes",
      "3. GET histórico para acompanhar status"
    ]
  },
  "observacoes_importantes": [
    "Todos os timestamps devem usar formato ISO 8601 (YYYY-MM-DDTHH:MM:SS)",
    "Permissões variam conforme o perfil do usuário",
    "Muitos endpoints requerem chaves de autorização específicas (ex: CadPermissions)",
    "Dados de exemplo incluem valores válidos para testes",
    "Campos com @NotBlank são obrigatórios e não podem estar vazios",
    "Campos com @NotNull são obrigatórios e não podem ser nulos",
    "Flags geralmente aceitam apenas 'S' (Sim) ou 'N' (Não)",
    "IDs de usuário e sessão são gerenciados automaticamente pelo sistema"
  ],
  "proximas_analises": [
